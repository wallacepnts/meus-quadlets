# Precisa bater exatamente com o endereço usado no navegador (NextAuth
# valida isso pra cookies/CSRF) — mesmo raciocínio do linkwarden.
NEXTAUTH_URL=https://karakeep.<seu-tailnet>.ts.net

# Depois de criar sua conta, considere travar novos cadastros (instância
# pessoal, sem motivo pra deixar aberta)
# DISABLE_SIGNUPS=true

# Habilita tagueamento automático por IA (opcional) — ver
# https://docs.karakeep.app/configuration pra outros provedores (Ollama
# local, etc.)
# OPENAI_API_KEY=

# Quantos jobs de crawling rodam em paralelo (default: 1)
# CRAWLER_NUM_WORKERS=1

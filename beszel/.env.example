# Hub — usada em links de notificação; usar a URL pela qual você acessa
# o painel (tsdproxy/tailnet).
APP_URL=https://beszel.<seu-tailnet>.ts.net

# Agent — hub e agent estão no mesmo host, conectam via socket
# compartilhado (não TCP/token exposto na rede) — ver README, seção
# "Instalação do zero".
HUB_URL=http://localhost:8090
LISTEN=/beszel_socket/beszel.sock
KEY_FILE=/run/secrets/beszel-key
TOKEN_FILE=/run/secrets/beszel-token

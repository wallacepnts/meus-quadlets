# UID/GID do usuário que roda o Podman (mesmo dono do volume) — a
# imagem faz usermod internamente, mesmo mecanismo do resto dos apps
# LinuxServer.io-like deste repositório.
PUID=1000
PGID=1000

TZ=America/Sao_Paulo

# URL pela qual você acessa (tsdproxy/tailnet) — usada em links
# gerados (convites, receitas compartilhadas).
BASE_URL=https://mealie.<seu-tailnet>.ts.net

# Cadastro aberto desligado — só a conta padrão (trocar senha no
# primeiro acesso, ver README) até você criar outras pela UI.
ALLOW_SIGNUP=false

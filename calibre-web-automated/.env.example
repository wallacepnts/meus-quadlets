# PUID/PGID do usuário que roda o Podman (mesmo dono dos volumes abaixo,
# senão a imagem não consegue escrever neles) — conferir com `id -u`/`id -g`.
PUID=1000
PGID=1000
TZ=America/Sao_Paulo

# Necessário só se você usa Hardcover como provedor de metadados
# (https://docs.hardcover.app/api/getting-started/)
# HARDCOVER_TOKEN=

# true se /calibre-library estiver num share de rede (NFS/SMB) — desliga
# WAL e troca inotify por polling, evita locks/permissão quebrados nesse
# cenário (default: false)
NETWORK_SHARE_MODE=false

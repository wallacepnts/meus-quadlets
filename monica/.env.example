# URL real de acesso (tsdproxy/tailnet) — usada em links gerados
# (convites, redefinição de senha).
APP_URL=https://monica.<seu-tailnet>.ts.net

# Confia no cabeçalho X-Forwarded-* de qualquer proxy na frente — sem
# isso o Laravel não sabe que a conexão chegou por HTTPS (o tsdproxy
# termina TLS antes), mesma classe de problema já visto no ownCloud
# (CSRF falhando por achar que a conexão é HTTP).
TRUSTED_PROXIES=*

# Sem SMTP configurado — grava e-mails (convite, redefinição de senha)
# no log em vez de enviar de verdade. Configurar MAIL_HOST/MAIL_PORT/
# MAIL_USERNAME/MAIL_PASSWORD se precisar de envio real.
MAIL_MAILER=log

TZ=America/Sao_Paulo

# A própria imagem ajusta o dono de /data pro uid interno (2999) no
# primeiro start — precisa disso porque o filesystem raiz é somente
# leitura e o volume é criado pelo host com outro dono.
TAKE_FILE_OWNERSHIP=true

# Opcionais do hook de calendário de aniversários (ver README) — cor do
# calendário (sem isso, escolhe uma cor aleatória) e lembrete em horas
# antes da meia-noite do dia do aniversário.
# BIRTHDAY_CALENDAR_COLOR=4986e7
# BIRTHDAY_REMINDER_AT_HOUR=9

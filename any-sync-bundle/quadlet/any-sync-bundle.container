[Unit]
Description=Any-Sync-Bundle server — modo AIO (Mongo + Redis embutidos)

[Container]
# Modo AIO (imagem SEM sufixo -minimal — essa variante embute MongoDB e
# Redis, sobe os dois como processos filhos do próprio binário Go via
# "start-all-in-one", em vez de precisar de containers externos). Trocado
# do modo modular (Postgres/Redis/mongo em containers separados) a pedido
# do usuário. Tag explícita — sem auto-update: mesmo motivo de sempre
# (regra 9 do README raiz, dado real + sem teste prévio possível em cada
# bump), não porque a versão do Mongo embutido seja "desconhecida" — o
# binário já detecta e falha limpo se o Mongo não sobe (ver Auto-update
# e Troubleshooting no README).
Image=ghcr.io/grishy/any-sync-bundle:1.4.3-2026-04-21
ContainerName=any-sync-bundle
PublishPort=33010:33010
PublishPort=33020:33020/udp

# Um único /data — a própria imagem organiza os subdiretórios
# (data/bundle-config.yml, data/storage/, data/mongo/, data/redis/),
# diferente do modo modular que precisava de três volumes separados.
Volume=%h/.config/containers/volumes/any-sync-bundle/data:/data:Z
EnvironmentFile=%h/.config/containers/env/any-sync-bundle.env

# Diferente da imagem -minimal (sem shell/utilitários, por isso o modo
# modular nunca teve HealthCmd), esta imagem é baseada em
# redis-stack-server + apt, tem bash — dá pra fazer um check TCP real na
# 33010 (mesmo truque /dev/tcp do lubelogger, regra 13 do README raiz).
HealthCmd=CMD-SHELL bash -c '</dev/tcp/127.0.0.1/33010' || exit 1
HealthInterval=15s
HealthTimeout=5s
HealthRetries=5
HealthStartPeriod=30s
Notify=healthy

# tsdproxy discovery — expõe o bundle na tailnet (TCP + QUIC/UDP)
Label=tsdproxy.enable=true
Label=tsdproxy.name=any-sync
Label=tsdproxy.port.sync=33010/tcp:33010/tcp
Label=tsdproxy.port.quic=33020/udp:33020/udp

# homepage — exibição no dashboard (ver ../homepage/)
Label=homepage.group=Self-Hosted
Label=homepage.name=Any-Sync-Bundle
Label=homepage.icon=anytype.svg
Label=homepage.description="Backend self-hosted do Anytype"

Label=wud.watch=true

[Service]
Restart=always
TimeoutStartSec=90

[Install]
WantedBy=default.target

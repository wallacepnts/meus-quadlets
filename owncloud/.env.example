OWNCLOUD_DOMAIN=owncloud.<seu-tailnet>.ts.net
OWNCLOUD_TRUSTED_DOMAINS=owncloud.<seu-tailnet>.ts.net
OWNCLOUD_ADMIN_USERNAME=admin

# tsdproxy termina TLS e repassa em HTTP puro pro container — sem isso,
# o ownCloud gera link/redirect em http:// (erro de CSRF, ver README).
# Tirar/mudar se for acessar só local via http://localhost:8094 em vez
# da tailnet.
OWNCLOUD_OVERWRITE_PROTOCOL=https

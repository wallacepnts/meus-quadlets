# UID/GID do usuário que roda o Podman — a imagem faz chown interno dos
# volumes (principalmente consume/) pra esse usuário. Ajustar antes do
# primeiro start (`id -u`/`id -g`).
USERMAP_UID=1000
USERMAP_GID=1000

TZ=America/Sao_Paulo
PAPERLESS_TIME_ZONE=America/Sao_Paulo

# Idioma padrão de OCR + idiomas adicionais a instalar — a imagem só traz
# eng/deu/ita/spa/fra por padrão; qualquer outro (como por) precisa estar
# em AMBAS as variáveis pra funcionar: PAPERLESS_OCR_LANGUAGES instala o
# pacote do Tesseract no primeiro start, PAPERLESS_OCR_LANGUAGE é o que
# de fato é usado no reconhecimento. Setar só uma das duas não funciona.
PAPERLESS_OCR_LANGUAGE=por
PAPERLESS_OCR_LANGUAGES=por

# Necessário só se for expor publicamente fora da tailnet
# PAPERLESS_URL=https://paperless.example.com

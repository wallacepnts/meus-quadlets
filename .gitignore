.env

# Dados de runtime dos containers — moram no host, nunca no repo.
volumes/
**/volumes/

# Backups gerados localmente (padrão dos READMEs de serviço).
*.tar.gz
*-backup-*.tar

# Lixo de editor / SO.
*.swp
*~
.DS_Store

